# Dependencies
node_modules/

# Build output
dist/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
*.itermcolors

# Logs
*.log
npm-debug.log*

# Test coverage
coverage/

# Environment
.env
.env.local
.env.*.local

# Package manager locks (use npm)
yarn.lock
pnpm-lock.yaml

# Generated by sequant init (for testing)
.sequant-manifest.json

# Dev-only MCP config overrides (prevents accidental commits of local paths)
# The distribution .mcp.json IS tracked via git add -f for self-hosted plugin installs.
# If you need a local dev version: git update-index --assume-unchanged .mcp.json
.mcp.json

# Entire CLI runtime data
.entire/

# Sequant runtime data (logs, settings, workflow state)
.sequant/*
# But track upstream assessment baseline and reports
!.sequant/upstream/

# Claude Code configuration
# Track hooks and skills, but ignore local settings
.claude/*
!.claude/hooks/
!.claude/skills/
!.claude/settings.json
.claude/settings.local.json
.claude/memory/

# Dev scripts (generated by init)
scripts/dev/

# Test projects
sequant/
